# Generated by Ansible - Do not edit manually
# For more options: http://rptl.io/configtxt

# Hardware interfaces
dtparam=audio={{ rpi_audio }}
#dtparam=i2c_arm={{ rpi_i2c }}
#dtparam=spi={{ rpi_spi }}

# Camera and Display detection
camera_auto_detect={{ rpi_camera_auto_detect }}
display_auto_detect={{ rpi_display_auto_detect }}
auto_initramfs=1

# DRM VC4 V3D driver
dtoverlay=vc4-kms-v3d
max_framebuffers=2
disable_fw_kms_setup=1
disable_overscan=1

# CPU and Architecture
arm_64bit={{ rpi_arm_64bit }}
arm_boost={{ rpi_arm_boost }}

# Fan control settings
dtparam=fan_temp0={{ rpi_fan_temp0 }}
dtparam=fan_temp0_hyst={{ rpi_fan_temp0_hyst }}
dtparam=fan_temp1={{ rpi_fan_temp1 }}
dtparam=fan_temp1_hyst={{ rpi_fan_temp1_hyst }}

[cm4]
otg_mode={{ rpi_cm4_otg_mode }}

[cm5]
dtoverlay=dwc2,dr_mode=host

[all]